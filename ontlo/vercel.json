{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/((?!assets/|favicon.ico|manifest.webmanifest|robots.txt).*)",
      "destination": "/index.html"
    }
  ]
}